{
  "expo": {
    "name": "Verdevia",
    "slug": "verdevia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "verdevia",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "jsEngine": "hermes"
    },
    "android": {
      "package": "com.leonmt.verdevia",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "jsEngine": "hermes"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o Verdevia acesse sua galeria para escolher a foto do perfil.",
          "cameraPermission": "Permita que o Verdevia use a camera para atualizar sua foto do perfil."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_white.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f4fe8d4-13f1-4fa3-83f2-cb36ff3fbe8f"
      }
    },
    "owner": "leonmt"
  }
}
